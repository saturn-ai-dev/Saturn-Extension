{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@src/*": [
        "./vendor/nanobrowser/chrome-extension/src/*"
      ],
      "@src/background/services/analytics": [
        "./services/nanobrowser/analytics.ts"
      ],
      "posthog-js/dist/module.no-external": [
        "./services/nanobrowser/posthogStub.ts"
      ],
      "@puppeteer/browsers": [
        "./services/nanobrowser/puppeteerBrowsersStub.ts"
      ],
      "@extension/storage": [
        "./vendor/nanobrowser/packages/storage"
      ],
      "@extension/storage/*": [
        "./vendor/nanobrowser/packages/storage/*"
      ],
      "@extension/i18n": [
        "./services/nanobrowser/i18n.ts"
      ],
      "@extension/*": [
        "./vendor/nanobrowser/packages/*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
